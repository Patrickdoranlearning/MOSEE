# MOSEE Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration
# Get these from your Neon project settings > API
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require


# Currency conversion API key (freecurrencyapi.com)
CURRENCY_API_KEY=your_key_here

# Optional: Debug mode (set to 1 to analyze fewer stocks for testing)
MOSEE_DEBUG=0

# AI Analysis - Gemini API key (for annual report analysis)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Auth.js (NextAuth) — Wealth Tree authentication
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — for "Sign in with Google")
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
